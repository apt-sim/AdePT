PROJECT_NAME           = "AdePT"
PROJECT_BRIEF          = "Accelerated demonstrator of electromagnetic Particle Transport"

OUTPUT_DIRECTORY       = _build/doxygen
CREATE_SUBDIRS         = NO

INPUT                  = ../include/AdePT ../src
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hh *.hpp *.hxx *.cuh *.icc *.cc *.cpp *.cu
EXCLUDE_PATTERNS       = */build/* */adept-build/* */_deps/*
EXCLUDE_SYMBOLS        = @*

GENERATE_HTML          = NO
GENERATE_XML           = YES
GENERATE_LATEX         = NO
XML_OUTPUT             = xml

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = NO

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
SORT_MEMBER_DOCS       = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
QUIET                  = YES

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             += __host__=
PREDEFINED             += __device__=
PREDEFINED             += __global__=
PREDEFINED             += __shared__=
PREDEFINED             += __constant__=
PREDEFINED             += __managed__=
PREDEFINED             += __launch_bounds__(x)=
PREDEFINED             += __align__(x)=
PREDEFINED             += __forceinline__=inline
PREDEFINED             += __forceinline=inline
PREDEFINED             += __restrict__=
PREDEFINED             += __restrict=
